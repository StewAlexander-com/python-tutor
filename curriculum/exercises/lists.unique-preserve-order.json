{
  "id": "lists.unique-preserve-order",
  "title": "Deduplicate, preserving order",
  "section": "Lists and dictionaries",
  "concepts": ["lists", "sets", "iteration", "order"],
  "prompt": "Write a function `unique(items)` that returns a list containing each value from *items* exactly once, in the order it first appeared.",
  "starter_code": "def unique(items):\n    # your code here\n    return []\n",
  "visible_tests": [
    "assert unique([]) == []",
    "assert unique([1, 2, 1, 3]) == [1, 2, 3]"
  ],
  "hidden_tests": [
    "assert unique(['a', 'b', 'a', 'c', 'b']) == ['a', 'b', 'c']",
    "assert unique([5, 5, 5]) == [5]",
    "assert unique([3, 1, 2]) == [3, 1, 2]"
  ],
  "references": [
    "https://docs.python.org/3/tutorial/datastructures.html#more-on-lists",
